LLM_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# Generic OpenAI-compatible API example (recommended for custom providers):
# LLM_PROVIDER=openai-compatible
# LLM_MODEL=provider/model-id
# LLM_MODEL_CANDIDATES=provider/model-id,provider/backup-model-id
# LLM_API_KEY=your_provider_api_key_here
# LLM_BASE_URL=https://provider.example.com/v1

# Mimo / ModelScope OpenAI-compatible API example:
# LLM_PROVIDER=mimo
# MIMO_MODEL=Qwen/Qwen3-235B-A22B
# MIMO_MODEL_CANDIDATES=Qwen/Qwen3-235B-A22B,Qwen/Qwen3-30B-A3B
# MIMO_API_KEY=your_modelscope_or_mimo_api_key_here
# MIMO_BASE_URL=https://api-inference.modelscope.cn/v1

LLM_TIMEOUT=40
RESEARCH_TIMEOUT=6
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=30
