LLM_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# Generic OpenAI-compatible API example (recommended for custom providers):
# LLM_PROVIDER=openai-compatible
# LLM_MODEL=provider/model-id
# LLM_MODEL_CANDIDATES=provider/model-id,provider/backup-model-id
# LLM_API_KEY=your_provider_api_key_here
# LLM_BASE_URL=https://provider.example.com/v1

# Xiaomi MiMo token-plan OpenAI-compatible API example:
# LLM_PROVIDER=mimo
# MIMO_MODEL=mimo-v2.5-pro
# MIMO_API_KEY=your_xiaomi_mimo_token_plan_api_key_here
# MIMO_BASE_URL=https://token-plan-...xiaomimimo.com/v1

# ModelScope OpenAI-compatible API example:
# LLM_PROVIDER=modelscope
# MIMO_MODEL=Qwen/Qwen3-235B-A22B
# MIMO_MODEL_CANDIDATES=Qwen/Qwen3-235B-A22B,Qwen/Qwen3-30B-A3B
# MIMO_API_KEY=your_modelscope_api_key_here
# MIMO_BASE_URL=https://api-inference.modelscope.cn/v1

# Frontend BYOK is also supported:
# Open zhiyuan-agent.html -> 模型配置, then enter an OpenAI-compatible Base URL,
# exact Model ID, and API Key. The key is stored only in the browser localStorage
# and is sent as per-request llm_config; it is not persisted by backend sessions.

LLM_TIMEOUT=40
RESEARCH_TIMEOUT=6
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=30
